rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function isAdmin() {
      return isEmailVerified() && (
        request.auth.token.email == 'parth20098@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Projects
    match /projects/{projectId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin() && isValidId(projectId);
    }

    // Certificates
    match /certificates/{certificateId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin() && isValidId(certificateId);
    }
    
    // Admin collection (if used for dynamic admin addition)
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; // Only manageable via console or service account for security
    }
  }
}
